######################################################################
## SysLab Project Standard .gitignore
## 작성일: 2026.04.05
######################################################################

### 1. Java & Build Tools (Gradle) ###
*.class
*.log
*.ctxt
.mtj.tmp/
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# Gradle build files
.gradle
/build/
/out/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

### 2. Secrets & Configs (CRITICAL: SECURITY) ###
# 절대 Git에 올라가면 안 되는 민감한 설정 파일들
src/main/resources/application-secret.yml
src/main/resources/application-local.yml
*.env

# 각자 로컬 환경이 다를 수 있는 Docker 설정
docker-compose.yml

### 3. Local Database Data ###
# 로컬 DB의 실제 데이터가 저장되는 폴더 (용량 및 보안 문제)
postgres_data/

### 4. IDE Settings (Editor Configs) ###
# IntelliJ
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/

# Eclipse & General IDE
.settings
.classpath
.project
bin/
.apt_generated
.factorypath
.springBeans
.sts4-cache

### 5. OS & Misc Files ###
.DS_Store
Thumbs.db
CLAUDE.md
HELP.md

